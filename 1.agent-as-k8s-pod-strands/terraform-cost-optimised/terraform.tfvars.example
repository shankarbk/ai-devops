###############################################################################
# terraform.tfvars.example — Copy to terraform.tfvars and customize
#
# cp terraform.tfvars.example terraform.tfvars
# then edit terraform.tfvars (it's gitignored)
###############################################################################

# Always us-east-1 — maximum Bedrock model availability + Free Tier benefits
aws_region = "us-east-1"

# Short name — used as prefix for all AWS resource names
cluster_name = "devops-agent"

# CHANGE THIS to your IP for security: run 'curl ifconfig.me' to find it
# Example: allowed_cidr = "203.0.113.42/32"
allowed_cidr = "0.0.0.0/0"

# t3.micro = Free Tier. Bump to t3.small if pods OOMKill.
node_instance_type = "t3.micro"

# Start with 1 node. The agent can scale_deployment to test scaling.
node_desired_size = 1

# K8s namespace and service account name — must match k8s/rbac.yaml
k8s_namespace         = "default"
agent_service_account = "devops-agent"
